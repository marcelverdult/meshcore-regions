{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marcelverdult/meshcore-regions/schema/todo.schema.json",
  "title": "Todo",
  "type": "object",
  "required": ["generated_at", "buckets"],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "buckets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["a","b","c","d","e","f","g","h","i","j","k","l","m","n","o","p","q","r","s","t","u","v","w","x","y","z","_"],
      "patternProperties": {
        "^[a-z_]$": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["raw", "reason", "first_seen"],
            "additionalProperties": false,
            "properties": {
              "raw": {
                "type": "string",
                "minLength": 1,
                "maxLength": 200
              },
              "reason": {
                "type": "string",
                "pattern": "^(no_root|invalid_chars|missing_parent:[a-z0-9]+(-[a-z0-9]+)*)$"
              },
              "first_seen": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      }
    }
  }
}
